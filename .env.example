PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/student_erp
CLIENT_URL=http://localhost:4200
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=8h
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_MAX=300

# local keeps files in backend/uploads. Use s3 for AWS S3, Cloudflare R2, MinIO, etc.
STORAGE_DRIVER=local
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

# AI exam generation (optional — uses built-in generator when not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@schoolerp.local
ADMIN_PASSWORD=Admin@12345

# Demo logins (created by npm run seed:demo)
TEACHER_EMAIL=teacher@schoolerp.local
TEACHER_PASSWORD=Teacher@12345
STUDENT_EMAIL=student@schoolerp.local
STUDENT_PASSWORD=Student@12345
PARENT_EMAIL=parent@schoolerp.local
PARENT_PASSWORD=Parent@12345
