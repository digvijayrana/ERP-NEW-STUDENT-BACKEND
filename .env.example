PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/student_erp
CLIENT_URL=https://erpms.vercel.app
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=8h
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_MAX=300

# ─── S3 Storage (REQUIRED for file uploads) ───
# Use AWS S3, Cloudflare R2, or MinIO (local dev)
# For local dev with MinIO: set S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=student-erp-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/student-erp-uploads

# ─── Splunk (centralized logging) ───
SPLUNK_HEC_URL=http://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=student-erp-hec-token
SPLUNK_INDEX=main

# ─── AI exam generation (optional) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── School Information (shown on PDFs) ───
SCHOOL_NAME=Delhi Public School
SCHOOL_ADDRESS=Plot No. 12, Sector 45, Gurugram, Haryana - 122003
SCHOOL_PHONE=+91 124-4567890
SCHOOL_EMAIL=info@dps-gurugram.edu.in
SCHOOL_WEBSITE=www.dps-gurugram.edu.in
SCHOOL_AFFILIATION=CBSE Affiliation No. 530726

# ─── Demo credentials ───
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@schoolerp.local
ADMIN_PASSWORD=Admin@12345
TEACHER_EMAIL=teacher@schoolerp.local
TEACHER_PASSWORD=Teacher@12345
STUDENT_EMAIL=student@schoolerp.local
STUDENT_PASSWORD=Student@12345
PARENT_EMAIL=parent@schoolerp.local
PARENT_PASSWORD=Parent@12345
