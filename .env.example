PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/student_erp
CLIENT_URL=https://erpms.vercel.app
# Public API base used in signed document URLs (must match what browsers call).
# Example: https://erp-new-student-backend.onrender.com/api
# Must also match frontend/vercel.json rewrite destination and environment.prod.ts apiBaseUrl.
PUBLIC_API_URL=
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=8h
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_MAX=300

# ─── Proxy hops (0 = browser talks to API directly; no gateway / ALB) ───
TRUST_PROXY=0
ROOT_DOMAIN=localhost
# Reject unknown CORS origins when true (default true in production)
CORS_STRICT=false
# Shared-process multi-tenant (Host → SchoolTenant → school_*_db)
MULTI_TENANT=false
CONTROL_PLANE_MONGODB_URI=mongodb://127.0.0.1:27017/super_admin_db
# TENANT_MONGO_URI_TEMPLATE=mongodb://127.0.0.1:27017/{{dbName}}
# This API instance is dedicated to one school when MULTI_TENANT=false
TENANT_SLUG=
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
TENANT_CONNECTION_POOL_MAX=100

# Redis — shared rate limits across ERP API replicas (optional but recommended in prod)
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_RATE_LIMIT_PREFIX=rl:erp:

# ─── File Storage ───
# local = backend/uploads/ (no S3)
# s3    = AWS S3 or MinIO
STORAGE_DRIVER=s3

# ─── AWS S3 (recommended for production) ───
S3_REGION=ap-south-1
S3_BUCKET=student-erp-uploads
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

# ─── MinIO (local dev only — alternative to AWS) ───
# STORAGE_DRIVER=s3
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin123
# S3_PUBLIC_BASE_URL=http://localhost:9000/student-erp-uploads

# ─── Splunk (optional) ───
# SPLUNK_HEC_URL=
# SPLUNK_HEC_TOKEN=
# SPLUNK_HEC_ENABLED=false

# ─── Email / SMTP ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="School ERP <youraddress@gmail.com>"

# ─── AI exam generation (optional) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── School Information (shown on PDFs) ───
SCHOOL_NAME=Delhi Public School
SCHOOL_ADDRESS=Plot No. 12, Sector 45, Gurugram, Haryana - 122003
SCHOOL_PHONE=+91 124-4567890
SCHOOL_EMAIL=info@dps-gurugram.edu.in
SCHOOL_WEBSITE=www.dps-gurugram.edu.in
SCHOOL_AFFILIATION=CBSE Affiliation No. 530726

# ─── Demo credentials ───
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@schoolerp.local
ADMIN_PASSWORD=Admin@12345
TEACHER_EMAIL=teacher@schoolerp.local
TEACHER_PASSWORD=Teacher@12345
STUDENT_EMAIL=student@schoolerp.local
STUDENT_PASSWORD=Student@12345
PARENT_EMAIL=parent@schoolerp.local
PARENT_PASSWORD=Parent@12345
